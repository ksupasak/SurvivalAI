{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "expo-web",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web", "--port", "8081", "--clear"],
      "port": 8081
    },
    {
      "name": "promo-website",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "website/public"],
      "port": 3001,
      "autoPort": true
    }
  ]
}
